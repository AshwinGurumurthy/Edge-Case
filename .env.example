# Copy to .env and fill in. The orchestrator loads this automatically.

# --- Context subtree (Anthropic) ---
# Get a key at https://console.anthropic.com/. If unset, the Context agents
# degrade to clearly-labelled [STUB] output so the graph still runs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Reviewer subtree + Big Boss + Debugger (local Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b        # heavier local model (Big Boss / Debugger / What-If)
OLLAMA_FAST_MODEL=gemma4:e2b   # lighter local model (General / Bugs)
# Tip: `ollama pull mistral` then set these to `mistral` to match the spec.

# --- Orchestration ---
WARROOM_MAX_ITERATIONS=2        # how many Boss<->Debugger refinement loops
