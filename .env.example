# Copy to context-agent/.env (or repo root) and fill in. python-dotenv loads it automatically.
#
# The pipeline runs with NO keys at all (local Ollama fallback). Set keys below
# to upgrade to the higher-quality cloud path.

# --- Cloud backend (optional but recommended) ---
# If set, the scanner uses Claude and the scenario agent uses Claude Haiku.
# If unset, both fall back to a local Ollama model.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6          # scanner model
SCENARIO_ANTHROPIC_MODEL=claude-haiku-4-5  # scenario model

# --- Web-search grounding for the scenario agent (optional) ---
# If set (and ANTHROPIC_API_KEY is set), the scenario agent researches real-world
# failure patterns via Tavily before writing scenarios. If unset, it skips search.
TAVILY_API_KEY=

# --- Local backend (used automatically when ANTHROPIC_API_KEY is unset) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=granite4:micro
# How much of the collected snapshot to send to a local model (smaller context window).
OLLAMA_MAX_BLOB_CHARS=120000

# --- Backend overrides (force a backend regardless of key presence) ---
# SCANNER_BACKEND=anthropic|ollama
# SCENARIO_BACKEND=anthropic|ollama

# --- Scanner tuning ---
# SCANNER_MAX_TOKENS=12000
