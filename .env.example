# Copy to .env (repo root) and fill in. python-dotenv loads it automatically.
#
# This repo hosts two subsystems that share these vars:
#   - context-agent/ : repo-link -> scanner -> scenario test-plan pipeline
#   - src/ (WARROOM) : multi-agent incident analysis
# Both run with NO keys at all (local Ollama fallback / [STUB] output). Keys upgrade quality.

# --- Cloud backend (optional but recommended) ---
# If set: context-agent scanner uses Claude Sonnet, scenario uses Claude Haiku,
# and WARROOM's Context subtree uses Claude (otherwise it emits [STUB] output).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6          # scanner / context model
SCENARIO_ANTHROPIC_MODEL=claude-haiku-4-5  # scenario-agent model

# --- Web-search grounding for the scenario agent (optional) ---
# If set (with ANTHROPIC_API_KEY), the scenario agent researches real-world
# failure patterns via Tavily before writing scenarios. If unset, it skips search.
TAVILY_API_KEY=

# --- Local backend (used automatically when ANTHROPIC_API_KEY is unset) ---
OLLAMA_HOST=http://localhost:11434
# Shared by both subsystems. Set to whatever you've `ollama pull`ed.
OLLAMA_MODEL=granite4:micro
OLLAMA_FAST_MODEL=granite4:micro   # WARROOM reviewer subtree (lighter model)
# How much of the collected snapshot to send to a local model (smaller context window).
OLLAMA_MAX_BLOB_CHARS=120000

# --- Backend overrides (force a backend regardless of key presence) ---
# SCANNER_BACKEND=anthropic|ollama
# SCENARIO_BACKEND=anthropic|ollama

# --- Tuning ---
# SCANNER_MAX_TOKENS=12000
# WARROOM_MAX_ITERATIONS=2          # WARROOM Boss<->Debugger refinement loops
